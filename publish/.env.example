# Copy to `.env` (repo root or publish/.env) and fill in. NEVER commit .env.

# --- Graph API backend (default, recommended) --------------------------
# See publish/GRAPH_API.md for how to obtain these.
# Using "Instagram API with Instagram Login" (no Facebook Page): leave
# IG_USER_ID as "me" and paste the token from the app's "Generate token" step.
IG_USER_ID=me
IG_ACCESS_TOKEN=your_instagram_access_token
# Route selector (default = Instagram Login host). For the Facebook-Page
# "Instagram Graph API" route instead, set:
# GRAPH_BASE_URL=https://graph.facebook.com/v21.0   and IG_USER_ID=<numeric id>
# Optional: serve slide images yourself instead of catbox.moe. If set, each
# slide URL becomes "$IMAGE_BASE_URL/<path from repo root>". For this public
# repo you could use the pushed build files, e.g.:
# IMAGE_BASE_URL=https://raw.githubusercontent.com/asanchezyali/social-media-posts/main

# --- instagrapi backend (unofficial, often blocked) -------------------
INSTAGRAM_USERNAME=your_instagram_handle
INSTAGRAM_PASSWORD=your_password
